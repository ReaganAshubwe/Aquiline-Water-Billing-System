# Admin
ADMIN_KEY=AQUALINE_ADMIN_2026

# MPESA Daraja
# true to enable real STK push requests
MPESA_ENABLED=false
# sandbox or live
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public HTTPS callback URL (must be reachable by Safaricom)
MPESA_CALLBACK_URL=

# SMS (Africa's Talking)
# true to enable real SMS sending
SMS_ENABLED=false
SMS_PROVIDER=africastalking
SMS_API_KEY=
SMS_USERNAME=
# Optional sender ID
SMS_SENDER_ID=
